# QuantPulse Backend Environment Variables
# Copy this file to .env and fill in your actual values

# =============================================================================
# Database Configuration
# =============================================================================
# For local development, SQLite is used automatically (no DATABASE_URL needed)
# For production (Railway/Render), set this to your PostgreSQL connection string
# DATABASE_URL=postgresql://user:password@host:port/database

# =============================================================================
# Authentication & Security
# =============================================================================
# Generate a strong secret key for JWT tokens
# You can generate one using: openssl rand -hex 32
SECRET_KEY=your-super-secret-key-change-this-in-production-use-openssl-rand-hex-32

# =============================================================================
# Stock Data Providers
# =============================================================================
# TwelveData API (Primary Provider)
TWELVEDATA_API_KEY=your_twelvedata_api_key_here

# Finnhub API (Fallback Provider)
FINNHUB_API_KEY=your_finnhub_api_key_here

# Provider Mode: auto, twelvedata, finnhub, demo
STOCK_PROVIDER=auto

# =============================================================================
# News API
# =============================================================================
NEWSAPI_KEY=your_news_api_key_here

# =============================================================================
# AI / LLM Services (for War Room Agents)
# =============================================================================
# Groq API (Fast & Free - Replaces Gemini)
GROQ_API_KEY=your_groq_api_key_here

# Serper API (for web search and live price fallback)
SERPER_API_KEY=your_serper_api_key_here

# Hugging Face Token (for downloading LSTM model)
HF_TOKEN=your_huggingface_token_here

# =============================================================================
# Server Configuration
# =============================================================================
# Port (Railway/Render will override this automatically)
PORT=8000

# Environment
ENV=development

# Logging Level
LOG_LEVEL=INFO

# =============================================================================
# Cache Configuration
# =============================================================================
CACHE_MAX_SIZE=10000
CACHE_DEFAULT_TTL=3600

# =============================================================================
# CORS Configuration (Optional)
# =============================================================================
# Comma-separated list of additional allowed origins
# ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
