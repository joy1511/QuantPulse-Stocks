# ✅ OPTIMIZED .dockerignore for Render Free Tier
# Reduces image size and speeds up builds

# Python cache
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# Virtual environments
venv/
env/
ENV/
.venv

# Development files
.env
.env.*
!.env.example
*.db
*.sqlite
*.sqlite3

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Testing
.pytest_cache/
.coverage
htmlcov/
.tox/

# Documentation
docs/
*.md
!README.md

# Git
.git/
.gitignore
.gitattributes

# Logs
*.log
logs/

# OS
.DS_Store
Thumbs.db

# Build artifacts
build/
dist/
*.egg-info/

# Jupyter
.ipynb_checkpoints/
*.ipynb

# Large model files (download at runtime from Hugging Face)
*.h5
*.weights.h5
*.pkl
models/

# Temporary files
tmp/
temp/
*.tmp
